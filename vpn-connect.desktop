# Adjust Exec/Icon paths to wherever the scripts are installed on your system.
[Desktop Entry]
Type=Application
Version=1.0
Name=GlobalProtect VPN — Connect
GenericName=VPN Connect
Comment=Connect to the Boeing GlobalProtect VPN
Exec=/opt/vpn-connect/vpn-connect.sh
Icon=network-vpn
